{
  "extends": "../../tsconfig.browser-base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "outDir": "./dist-types",
    "rootDir": ".",
    "composite": true,
    "allowJs": true,
    "strict": true,
    "checkJs": true,
    "emitDeclarationOnly": true,
    "target": "esnext",
    "lib": ["DOM", "ESNext"],
    "moduleResolution": "node16",
    "declaration": true,
    "esModuleInterop": true,
    "alwaysStrict": true,
    "skipLibCheck": true
  },
  "references": [],
  "include": ["lit-element.js", "html-element.js", "types.ts"],
  "exclude": ["dist", "types", "test-types"]
}
